{
  "all": true,
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "test-project/**",
    "coverage/**",
    "src/index.ts",
    "src/**/types.ts",
    "*.config.js",
    "*.config.ts"
  ],
  "reporter": ["text-summary", "text"],
  "lines": 80,
  "functions": 80,
  "branches": 80,
  "statements": 80,
  "check-coverage": false,
  "skip-full": false
}
